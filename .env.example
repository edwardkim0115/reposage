APP_ENV=development
LOG_LEVEL=INFO
POSTGRES_DB=reposage
POSTGRES_USER=reposage
POSTGRES_PASSWORD=reposage
DATABASE_URL=postgresql+psycopg://reposage:reposage@postgres:5432/reposage
SYNC_DATABASE_URL=postgresql+psycopg://reposage:reposage@postgres:5432/reposage
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=reposage-index
OPENAI_API_KEY=
OPENAI_RESPONSE_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
GITHUB_TOKEN=
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
STORAGE_ROOT=/app/storage
MAX_REPOSITORY_SIZE_MB=100
MAX_FILE_SIZE_KB=256
MAX_TOTAL_FILES=5000
CHUNK_MAX_CHARS=2200
CHUNK_OVERLAP_LINES=10

